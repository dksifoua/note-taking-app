{
    "name": "note-taking-app",
    "type": "module",
    "module": "index.ts",
    "private": true,
    "workspaces": ["apps/*", "packages/*"],
    "scripts": {
        "api:dev": "bun run --filter note-taking-api --env-file=.env.api.local dev",
        "ui:dev": "bun run --filter note-taking-ui dev",
        "dev": "concurrently -n 'api,ui' -c 'green,blue' 'bun run api:dev' 'bun run ui:dev'"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^9.2.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
